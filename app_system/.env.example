# API Configuration for Research Agents
# Copy this file to .env and fill in your credentials

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your API credentials
# 3. Never commit .env to git (it's in .gitignore)
# =============================================================================

# API Provider (for documentation)
# Options: openai, anthropic, gemini, martinai, custom
API_PROVIDER=openai

# API Credentials (REQUIRED)
API_KEY=your_api_key_here
API_BASE=https://api.openai.com/v1

# Model Configuration
# Primary model (used by section evaluator - needs strong reasoning)
MODEL_PRIMARY=gpt-4

# Secondary model (used by referee debate system with thinking mode)
MODEL_SECONDARY=gpt-4

# Tertiary model (legacy/backup)
MODEL_TERTIARY=gpt-3.5-turbo

# =============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT PROVIDERS
# =============================================================================

# --- OpenAI ---
# API_PROVIDER=openai
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
# MODEL_PRIMARY=gpt-4
# MODEL_SECONDARY=gpt-4
# MODEL_TERTIARY=gpt-3.5-turbo

# --- Anthropic ---
# API_PROVIDER=anthropic
# API_KEY=sk-ant-...
# API_BASE=https://api.anthropic.com/v1
